# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_EXPORT_ENDPOINT: Optional absolute or relative URL for the preset export worker.
# Defaults to /api/export if omitted.
VITE_EXPORT_ENDPOINT="https://your-worker.example.workers.dev/api/export"
